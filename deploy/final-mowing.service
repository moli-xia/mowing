[Unit]
Description=Final Mowing Game Server
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/final-mowing
EnvironmentFile=/etc/final-mowing.env
ExecStart=/usr/bin/python3 /var/www/final-mowing/server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
